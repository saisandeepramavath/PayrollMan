            "url": {
              "raw": "{{baseUrl}}/punch_entries/clock-out",
              "host": ["{{baseUrl}}"],
              "path": ["punch_entries", "clock-out"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Punch Entries",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/punch_entries/",
              "host": ["{{baseUrl}}"],
              "path": ["punch_entries", ""]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"API Development\",\n  \"description\": \"Backend API development project\",\n  \"start_date\": \"2026-04-01T00:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/",
              "host": ["{{baseUrl}}"],
              "path": ["projects", ""]
            }
          },
          "response": []
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/projects/",
              "host": ["{{baseUrl}}"],
              "path": ["projects", ""]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
