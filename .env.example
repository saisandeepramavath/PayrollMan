# Application Settings
APP_NAME=Timecard Management API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/timecard_db
# For SQLite in development: sqlite:///./timecard.db

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1
